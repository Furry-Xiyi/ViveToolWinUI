<Page
    x:Class="ViveToolWinUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="24">

            <!-- 外观与材质组 -->
            <StackPanel Spacing="12" HorizontalAlignment="Stretch">

                <!-- 分组标题 -->
                <TextBlock x:Uid="AppearanceGroup"
               FontSize="20"
               FontWeight="SemiBold"
               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                <!-- 应用主题折叠卡 -->
                <muxc:Expander x:Name="ThemeExpander"
                   IsExpanded="False"
                   HorizontalAlignment="Stretch"
                   HorizontalContentAlignment="Left"
                   MinHeight="70">

                    <muxc:Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE706;" Width="30" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock x:Uid="Settings_Theme"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock x:Uid="ThemeHeaderSubtitle"
                               FontSize="12"
                               Opacity="0.7"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </muxc:Expander.Header>

                    <muxc:Expander.Content>
                        <StackPanel Spacing="8" Padding="12,0,0,12" HorizontalAlignment="Left">
                            <RadioButton x:Name="ThemeSystem"
                             x:Uid="Theme_System"
                             Checked="Theme_Checked"
                             Tag="System"/>

                            <RadioButton x:Name="ThemeLight"
                             x:Uid="Theme_Light"
                             Checked="Theme_Checked"
                             Tag="Light"/>

                            <RadioButton x:Name="ThemeDark"
                             x:Uid="Theme_Dark"
                             Checked="Theme_Checked"
                             Tag="Dark"/>
                        </StackPanel>
                    </muxc:Expander.Content>
                </muxc:Expander>

                <!-- 背景材质折叠卡 -->
                <muxc:Expander x:Name="MaterialExpander"
                   IsExpanded="False"
                   HorizontalAlignment="Stretch"
                   HorizontalContentAlignment="Left"
                   MinHeight="70">

                    <muxc:Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE2B1;" Width="30" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock x:Uid="Settings_Backdrop"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock x:Uid="MaterialHeaderSubtitle"
                               FontSize="12"
                               Opacity="0.7"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </muxc:Expander.Header>

                    <muxc:Expander.Content>
                        <StackPanel Spacing="8" Padding="12,0,0,12" HorizontalAlignment="Left">

                            <RadioButton x:Name="MaterialMica"
                             x:Uid="Backdrop_Mica"
                             Checked="Material_Checked"
                             Tag="Mica"/>

                            <RadioButton x:Name="MaterialMicaAlt"
                             x:Uid="Backdrop_Mica_Alt"
                             Checked="Material_Checked"
                             Tag="Mica_Alt"/>

                            <RadioButton x:Name="MaterialAcrylic"
                             x:Uid="Backdrop_Acrylic"
                             Checked="Material_Checked"
                             Tag="Acrylic"/>

                        </StackPanel>
                    </muxc:Expander.Content>
                </muxc:Expander>

            </StackPanel>

            <!-- ViveTool 内核管理 -->
            <StackPanel Spacing="12">
                <TextBlock x:Uid="Settings_Kernel" 
                          Style="{StaticResource SubtitleTextBlockStyle}"/>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                       CornerRadius="8" Padding="16">
                    <StackPanel Spacing="16">

                        <!-- 版本信息 -->
                        <StackPanel Spacing="8">
                            <TextBlock x:Uid="Settings_CurrentVersion" FontWeight="SemiBold"/>
                            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                   CornerRadius="4" Padding="12">
                                <TextBlock x:Name="TxtVersion" 
                                          FontFamily="Consolas"
                                          TextWrapping="Wrap"
                                          IsTextSelectionEnabled="True"/>
                            </Border>
                        </StackPanel>

                        <!-- 更新选项 -->
                        <muxc:ToggleSwitch x:Name="AutoUpdateToggle" 
                                          x:Uid="Kernel_AutoUpdate"
                                          Toggled="AutoUpdate_Toggled"/>

                        <!-- 操作按钮 -->
                        <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="BtnCheckUpdate" 
                                       x:Uid="Kernel_CheckUpdate"
                                       Click="CheckUpdate_Click"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,0,4,0"/>

                                <Button x:Name="BtnOpenFolder" 
                                       x:Uid="Kernel_OpenFolder"
                                       Click="OpenFolder_Click"
                                       HorizontalAlignment="Stretch"
                                       Grid.Column="1"
                                       Margin="4,0,0,0"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="BtnBackup" 
                                       x:Uid="Kernel_Backup"
                                       Click="Backup_Click"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,0,4,0"/>

                                <Button x:Name="BtnRestore" 
                                       x:Uid="Kernel_Restore"
                                       Click="Restore_Click"
                                       HorizontalAlignment="Stretch"
                                       Grid.Column="1"
                                       Margin="4,0,0,0"/>
                            </Grid>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 应用设置 -->
            <StackPanel Spacing="12">
                <TextBlock x:Uid="Settings_App" 
                          Style="{StaticResource SubtitleTextBlockStyle}"/>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                       CornerRadius="8" Padding="16">
                    <StackPanel Spacing="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BtnExportSettings" 
                                   x:Uid="App_ExportSettings"
                                   Click="ExportSettings_Click"
                                   HorizontalAlignment="Stretch"
                                   Margin="0,0,4,0"/>

                            <Button x:Name="BtnImportSettings" 
                                   x:Uid="App_ImportSettings"
                                   Click="ImportSettings_Click"
                                   HorizontalAlignment="Stretch"
                                   Grid.Column="1"
                                   Margin="4,0,0,0"/>
                        </Grid>

                        <Button x:Name="BtnResetSettings" 
                               x:Uid="App_ResetSettings"
                               Click="ResetSettings_Click"
                               HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 关于 -->
            <StackPanel Spacing="12">
                <TextBlock x:Uid="Settings_About" 
                          Style="{StaticResource SubtitleTextBlockStyle}"/>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                       CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">

                        <!-- 应用信息 -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Image x:Name="AppLogo" 
                                  Width="48" Height="48" 
                                  Stretch="Uniform"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TxtAppName" 
                                          FontSize="18" 
                                          FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtAppVersion" 
                                          FontSize="12" 
                                          Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 链接 -->
                        <StackPanel Spacing="4">
                            <HyperlinkButton x:Name="BtnGitHub" 
                                           x:Uid="About_GitHub"
                                           NavigateUri="https://github.com/Furry-Xiyi/ViveToolWinUI"/>
                            <HyperlinkButton x:Name="BtnFeedback" 
                                           x:Uid="About_Feedback"
                                           Click="Feedback_Click"/>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>