<Page
    x:Class="ViveToolWinUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="24" MaxWidth="800">

            <!-- 外观设置 -->
            <StackPanel Spacing="12">
                <TextBlock x:Uid="Settings_Appearance" 
                          Style="{StaticResource SubtitleTextBlockStyle}"/>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                       CornerRadius="8" Padding="16">
                    <StackPanel Spacing="16">

                        <!-- 主题选择 -->
                        <StackPanel Spacing="8">
                            <TextBlock x:Uid="Settings_Theme" FontWeight="SemiBold"/>
                            <muxc:RadioButtons x:Name="ThemeSelector" SelectionChanged="Theme_Changed">
                                <RadioButton x:Uid="Theme_System" Tag="System"/>
                                <RadioButton x:Uid="Theme_Light" Tag="Light"/>
                                <RadioButton x:Uid="Theme_Dark" Tag="Dark"/>
                            </muxc:RadioButtons>
                        </StackPanel>

                        <!-- 背景材质 -->
                        <StackPanel Spacing="8">
                            <TextBlock x:Uid="Settings_Backdrop" FontWeight="SemiBold"/>
                            <muxc:RadioButtons x:Name="BackdropSelector" SelectionChanged="Backdrop_Changed">
                                <RadioButton x:Uid="Backdrop_Mica" Tag="Mica"/>
                                <RadioButton x:Uid="Backdrop_Acrylic" Tag="Acrylic"/>
                            </muxc:RadioButtons>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ViveTool 内核管理 -->
            <StackPanel Spacing="12">
                <TextBlock x:Uid="Settings_Kernel" 
                          Style="{StaticResource SubtitleTextBlockStyle}"/>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                       CornerRadius="8" Padding="16">
                    <StackPanel Spacing="16">

                        <!-- 版本信息 -->
                        <StackPanel Spacing="8">
                            <TextBlock x:Uid="Settings_CurrentVersion" FontWeight="SemiBold"/>
                            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                   CornerRadius="4" Padding="12">
                                <TextBlock x:Name="TxtVersion" 
                                          FontFamily="Consolas"
                                          TextWrapping="Wrap"
                                          IsTextSelectionEnabled="True"/>
                            </Border>
                        </StackPanel>

                        <!-- 更新选项 -->
                        <muxc:ToggleSwitch x:Name="AutoUpdateToggle" 
                                          x:Uid="Kernel_AutoUpdate"
                                          Toggled="AutoUpdate_Toggled"/>

                        <!-- 操作按钮 -->
                        <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="BtnCheckUpdate" 
                                       x:Uid="Kernel_CheckUpdate"
                                       Click="CheckUpdate_Click"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,0,4,0"/>

                                <Button x:Name="BtnOpenFolder" 
                                       x:Uid="Kernel_OpenFolder"
                                       Click="OpenFolder_Click"
                                       HorizontalAlignment="Stretch"
                                       Grid.Column="1"
                                       Margin="4,0,0,0"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="BtnBackup" 
                                       x:Uid="Kernel_Backup"
                                       Click="Backup_Click"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,0,4,0"/>

                                <Button x:Name="BtnRestore" 
                                       x:Uid="Kernel_Restore"
                                       Click="Restore_Click"
                                       HorizontalAlignment="Stretch"
                                       Grid.Column="1"
                                       Margin="4,0,0,0"/>
                            </Grid>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 应用设置 -->
            <StackPanel Spacing="12">
                <TextBlock x:Uid="Settings_App" 
                          Style="{StaticResource SubtitleTextBlockStyle}"/>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                       CornerRadius="8" Padding="16">
                    <StackPanel Spacing="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BtnExportSettings" 
                                   x:Uid="App_ExportSettings"
                                   Click="ExportSettings_Click"
                                   HorizontalAlignment="Stretch"
                                   Margin="0,0,4,0"/>

                            <Button x:Name="BtnImportSettings" 
                                   x:Uid="App_ImportSettings"
                                   Click="ImportSettings_Click"
                                   HorizontalAlignment="Stretch"
                                   Grid.Column="1"
                                   Margin="4,0,0,0"/>
                        </Grid>

                        <Button x:Name="BtnResetSettings" 
                               x:Uid="App_ResetSettings"
                               Click="ResetSettings_Click"
                               HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 关于 -->
            <StackPanel Spacing="12">
                <TextBlock x:Uid="Settings_About" 
                          Style="{StaticResource SubtitleTextBlockStyle}"/>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                       CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">

                        <!-- 应用信息 -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Image x:Name="AppLogo" 
                                  Width="48" Height="48" 
                                  Stretch="Uniform"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TxtAppName" 
                                          FontSize="18" 
                                          FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtAppVersion" 
                                          FontSize="12" 
                                          Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 链接 -->
                        <StackPanel Spacing="4">
                            <HyperlinkButton x:Name="BtnGitHub" 
                                           x:Uid="About_GitHub"
                                           NavigateUri="https://github.com/Furry-Xiyi/ViveToolWinUI"/>
                            <HyperlinkButton x:Name="BtnFeedback" 
                                           x:Uid="About_Feedback"
                                           Click="Feedback_Click"/>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>