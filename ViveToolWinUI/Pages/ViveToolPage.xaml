<Page
    x:Class="ViveToolWinUI.Pages.ViveToolPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="24" MaxWidth="1000">

            <!-- 标题 -->
            <TextBlock x:Uid="ViveTool_Title" Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- 快速命令区 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                   CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <TextBlock x:Uid="ViveTool_QuickCommands" 
                              Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnQuery" x:Uid="ViveTool_Query" 
                                Click="Query_Click" Margin="4" Grid.Row="0" Grid.Column="0"/>
                        <Button x:Name="BtnFullReset" x:Uid="ViveTool_FullReset" 
                                Click="FullReset_Click" Margin="4" Grid.Row="0" Grid.Column="1"/>
                        <Button x:Name="BtnChangeStamp" x:Uid="ViveTool_ChangeStamp" 
                                Click="ChangeStamp_Click" Margin="4" Grid.Row="0" Grid.Column="2"/>
                        <Button x:Name="BtnVersion" x:Uid="ViveTool_Version" 
                                Click="Version_Click" Margin="4" Grid.Row="0" Grid.Column="3"/>

                        <Button x:Name="BtnExport" x:Uid="ViveTool_Export" 
                                Click="Export_Click" Margin="4" Grid.Row="1" Grid.Column="0"/>
                        <Button x:Name="BtnImport" x:Uid="ViveTool_Import" 
                                Click="Import_Click" Margin="4" Grid.Row="1" Grid.Column="1"/>
                        <Button x:Name="BtnLkgStatus" x:Uid="ViveTool_LkgStatus" 
                                Click="LkgStatus_Click" Margin="4" Grid.Row="1" Grid.Column="2"/>
                        <Button x:Name="BtnFixLkg" x:Uid="ViveTool_FixLkg" 
                                Click="FixLkg_Click" Margin="4" Grid.Row="1" Grid.Column="3"/>

                        <Button x:Name="BtnQuerySubs" x:Uid="ViveTool_QuerySubs" 
                                Click="QuerySubs_Click" Margin="4" Grid.Row="2" Grid.Column="0"/>
                        <Button x:Name="BtnAddSub" x:Uid="ViveTool_AddSub" 
                                Click="AddSub_Click" Margin="4" Grid.Row="2" Grid.Column="1"/>
                        <Button x:Name="BtnDelSub" x:Uid="ViveTool_DelSub" 
                                Click="DelSub_Click" Margin="4" Grid.Row="2" Grid.Column="2"/>
                        <Button x:Name="BtnFixPriority" x:Uid="ViveTool_FixPriority" 
                                Click="FixPriority_Click" Margin="4" Grid.Row="2" Grid.Column="3"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 功能操作区 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                   CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <TextBlock x:Uid="ViveTool_FeatureManagement" 
                              Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <TextBox x:Name="TxtFeatureId" 
                            x:Uid="ViveTool_FeatureIdBox"
                            PlaceholderText="12345678,87654321"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="BtnEnable" x:Uid="ViveTool_Enable" 
                                Click="Enable_Click" 
                                Style="{StaticResource AccentButtonStyle}"
                                MinWidth="120"/>
                        <Button x:Name="BtnDisable" x:Uid="ViveTool_Disable" 
                                Click="Disable_Click"
                                MinWidth="120"/>
                        <Button x:Name="BtnReset" x:Uid="ViveTool_Reset" 
                                Click="Reset_Click"
                                MinWidth="120"/>
                    </StackPanel>

                    <CheckBox x:Name="ChkReboot" x:Uid="ViveTool_AutoReboot"/>
                </StackPanel>
            </Border>

            <!-- 自定义命令区 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                   CornerRadius="8" Padding="16">
                <StackPanel Spacing="16">
                    <TextBlock x:Uid="ViveTool_CustomCommand" 
                              Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <TextBox x:Name="TxtCustomArgs" 
                            x:Uid="ViveTool_CustomBox"
                            PlaceholderText="/help"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="BtnRunCustom" x:Uid="ViveTool_RunCustom" 
                                Click="RunCustom_Click"
                                Style="{StaticResource AccentButtonStyle}"
                                MinWidth="150"/>
                        <Button x:Name="BtnViewOutput" x:Uid="ViveTool_ViewOutput" 
                                Click="ViewOutput_Click"
                                MinWidth="120"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 历史记录 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                   CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <Grid>
                        <TextBlock x:Uid="ViveTool_History" 
                                  Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <Button x:Name="BtnClearHistory" x:Uid="ViveTool_ClearHistory" 
                                Click="ClearHistory_Click"
                                HorizontalAlignment="Right"/>
                    </Grid>

                    <ListView x:Name="LvHistory" 
                             MaxHeight="200"
                             SelectionMode="Single"
                             ItemClick="History_ItemClick"
                             IsItemClickEnabled="True">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Verb}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Args}" Grid.Column="1" 
                                              TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>