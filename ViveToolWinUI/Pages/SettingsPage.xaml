<Page
    x:Class="ViveToolWinUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <ScrollViewer Padding="15" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="32" HorizontalAlignment="Stretch">

            <!-- 外观与材质组 -->
            <StackPanel Spacing="12" HorizontalAlignment="Stretch">
                <TextBlock x:Uid="AppearanceGroup" FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                <!-- 应用主题折叠卡 -->
                <muxc:Expander x:Name="ThemeExpander" IsExpanded="False"
                               HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" MinHeight="70">
                    <muxc:Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE706;" Width="30" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock x:Uid="ThemeHeaderTitle" FontSize="16" FontWeight="SemiBold" 
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock x:Uid="ThemeHeaderSubtitle" FontSize="12" Opacity="0.7" 
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </muxc:Expander.Header>

                    <muxc:Expander.Content>
                        <StackPanel Spacing="8" Padding="12,0,0,12" HorizontalAlignment="Left">
                            <RadioButton x:Name="ThemeSystem" x:Uid="ThemeSystem" Content="" Checked="Theme_Checked" Tag="System"/>
                            <RadioButton x:Name="ThemeLight" x:Uid="ThemeLight" Content="" Checked="Theme_Checked" Tag="Light"/>
                            <RadioButton x:Name="ThemeDark" x:Uid="ThemeDark" Content="" Checked="Theme_Checked" Tag="Dark"/>
                        </StackPanel>
                    </muxc:Expander.Content>
                </muxc:Expander>

                <!-- 背景材质折叠卡 -->
                <muxc:Expander x:Name="MaterialExpander" IsExpanded="False"
                               HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" MinHeight="70">
                    <muxc:Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE2B1;" Width="30" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock x:Uid="MaterialHeaderTitle" FontSize="16" FontWeight="SemiBold" 
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock x:Uid="MaterialHeaderSubtitle" FontSize="12" Opacity="0.7" 
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </muxc:Expander.Header>

                    <muxc:Expander.Content>
                        <StackPanel Spacing="8" Padding="12,0,0,12" HorizontalAlignment="Left">
                            <RadioButton x:Name="MaterialAcrylic" x:Uid="MaterialAcrylic" Content="" Checked="Material_Checked" Tag="Acrylic"/>
                            <RadioButton x:Name="MaterialMica" x:Uid="MaterialMica" Content="" Checked="Material_Checked" Tag="Mica"/>
                            <RadioButton x:Name="MaterialMicaAlt" x:Uid="MaterialMicaAlt" Content="" Checked="Material_Checked" Tag="MicaAlt"/>
                        </StackPanel>
                    </muxc:Expander.Content>
                </muxc:Expander>
            </StackPanel>

            <!-- ViveTool 内核 / 行为 -->
            <StackPanel Spacing="12" HorizontalAlignment="Stretch">
                <TextBlock x:Uid="BehaviorGroup" FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                <!-- 内核管理折叠卡 -->
                <muxc:Expander x:Name="KernelExpander" IsExpanded="True"
                               HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" MinHeight="70">
                    <muxc:Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE9D9;" Width="30" FontSize="20" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock x:Uid="KernelHeaderTitle" FontSize="16" FontWeight="SemiBold" 
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock x:Uid="KernelHeaderSubtitle" FontSize="12" Opacity="0.7" 
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </muxc:Expander.Header>

                    <muxc:Expander.Content>
                        <StackPanel Spacing="8" Padding="12,0,0,12" HorizontalAlignment="Stretch">

                            <!-- 按钮区：Grid 两行三列 -->
                            <Grid Margin="0,0,0,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 第一行按钮 -->
                                <Button x:Name="BtnCheckViveToolUpdate" x:Uid="BtnCheckViveToolUpdate"
                    Click="CheckViveToolUpdate_Click" Margin="6" Grid.Row="0" Grid.Column="0"/>
                                <Button x:Name="BtnCustomUpdateLink" x:Uid="BtnCustomUpdateLink"
                    Click="CustomUpdateLink_Click" Margin="6" Grid.Row="0" Grid.Column="1"/>
                                <Button x:Name="BtnImportKernelZip" x:Uid="BtnImportKernelZip"
                    Click="ImportKernelZip_Click" Margin="6" Grid.Row="0" Grid.Column="2"/>

                                <!-- 第二行按钮 -->
                                <Button x:Name="BtnOpenCoreFolder" x:Uid="BtnOpenCoreFolder"
                    Click="BtnOpenCoreFolder_Click" Margin="6" Grid.Row="1" Grid.Column="0"/>
                                <Button x:Name="BtnBackupCore" x:Uid="BtnBackupCore"
                    Click="BtnBackupCore_Click" Margin="6" Grid.Row="1" Grid.Column="1"/>
                                <Button x:Name="BtnRestoreCore" x:Uid="BtnRestoreCore"
                    Click="BtnRestoreCore_Click" Margin="6" Grid.Row="1" Grid.Column="2"/>
                            </Grid>

                            <!-- 自动更新开关 -->
                            <muxc:ToggleSwitch x:Name="AutoUpdateViveToolToggle" x:Uid="AutoUpdateViveToolToggle" Header=""
                           Toggled="AutoUpdateViveToolToggle_Toggled" Margin="0,8,0,0"/>
                        </StackPanel>
                    </muxc:Expander.Content>
                </muxc:Expander>

                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,8"/>

                <VariableSizedWrapGrid Orientation="Horizontal" Margin="0,0,0,8" HorizontalAlignment="Left">
                    <Button x:Name="BtnExportSettings" x:Uid="BtnExportSettings" Content=""
                            Click="BtnExportSettings_Click" Width="160" Margin="6"/>
                    <Button x:Name="BtnImportSettings" x:Uid="BtnImportSettings" Content=""
                            Click="BtnImportSettings_Click" Width="160" Margin="6"/>
                    <Button x:Name="BtnResetSettings" x:Uid="BtnResetSettings" Content=""
                            Click="BtnResetSettings_Click" Width="120" Margin="6"/>
                    <Button x:Name="BtnTestViveTool" x:Uid="BtnTestViveTool" Content=""
                            Click="BtnTestViveTool_Click" Width="160" Margin="6"/>
                </VariableSizedWrapGrid>
            </StackPanel>

            <!-- 关于 -->
            <StackPanel Spacing="12" HorizontalAlignment="Stretch">
                <TextBlock x:Uid="AboutTitle" FontSize="20" FontWeight="SemiBold"
               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                <muxc:Expander x:Name="AboutExpander" IsExpanded="False"
                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" MinHeight="100">
                    <muxc:Expander.Header>
                        <!-- 给整个 Header 加左边距，比如 12px -->
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="7,0,7,0">
                            <Grid Width="30" Height="30" VerticalAlignment="Center">
                                <Image x:Name="AppLogoImage" Stretch="Uniform"
                   Visibility="Collapsed"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <FontIcon x:Name="AppLogo" Glyph="&#xE7C1;" FontSize="20"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>

                            <StackPanel>
                                <TextBlock x:Name="AppTitle" FontSize="18" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock x:Name="AppPublisher" FontSize="12" Opacity="0.7"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock x:Name="AppVersion" FontSize="12" Opacity="0.7"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </muxc:Expander.Header>

                    <muxc:Expander.Content>
                        <StackPanel Spacing="8" Padding="12,0,0,12" HorizontalAlignment="Left">
                            <HyperlinkButton x:Name="JoinQQButton" x:Uid="JoinQQButton" Content=""
                                 Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                 HorizontalAlignment="Left"/>
                            <HyperlinkButton x:Name="JoinDiscordButton" x:Uid="JoinDiscordButton" Content=""
                                 Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                 HorizontalAlignment="Left"/>
                        </StackPanel>
                    </muxc:Expander.Content>
                </muxc:Expander>
            </StackPanel>

            <!-- 反馈按钮 -->
            <HyperlinkButton x:Name="FeedbackButton" x:Uid="FeedbackButton" Content=""
                 Click="SendFeedback_Click"
                 Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                 HorizontalAlignment="Left"/>
        </StackPanel>
    </ScrollViewer>
</Page>